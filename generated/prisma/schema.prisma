// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// NOTE: When using mysql or sqlserver, uncomment the //@db.Text annotations in model Account below
// Further reading:
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model User {
  id            String    @id
  name          String //@db.Text
  email         String
  emailVerified Boolean   @default(false)
  image         String? //@db.Text
  preferences   String? // JSON string for user preferences
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  accounts      Account[]
  posts         Post[]

  // Quadratic relations
  memberships             WorkspaceMember[]
  projectsLead            Project[]                 @relation(name: "ProjectLead")
  assignedIssues          Issue[]                   @relation(name: "AssignedIssues")
  createdIssues           Issue[]                   @relation(name: "CreatedIssues")
  comments                Comment[]
  issueHistory            IssueHistory[]
  notifications           Notification[]            @relation("UserNotifications")
  notificationsTriggered  Notification[]            @relation("NotificationActor")
  notificationPreferences NotificationPreferences[]
  timeEntries             TimeEntry[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// Quadratic Models - Project Management

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  String? // JSON string for workspace settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members                 WorkspaceMember[]
  teams                   Team[]
  projects                Project[]
  issues                  Issue[]
  cycles                  Cycle[]
  labels                  Label[]
  notifications           Notification[]
  notificationPreferences NotificationPreferences[]
  templates               Template[]
  automationRules         AutomationRule[]
  automationLogs          AutomationLog[]
  pullRequests            GitHubPullRequest[]
  timeEntries             TimeEntry[]
  apiKeys                 ApiKey[]
  webhooks                Webhook[]

  @@map("workspace")
}

model WorkspaceMember {
  id       String        @id @default(cuid())
  role     WorkspaceRole @default(MEMBER)
  joinedAt DateTime      @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_member")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  key       String // e.g., "ENG"
  color     String // e.g., "#5E6AD2"
  createdAt DateTime @default(now())

  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects        Project[]
  issues          Issue[]
  cycles          Cycle[]
  labels          Label[]
  templates       Template[]
  automationRules AutomationRule[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("team")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  color       String        @default("#5E6AD2")
  status      ProjectStatus @default(PLANNED)
  startDate   DateTime?
  targetDate  DateTime?
  createdAt   DateTime      @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        User?     @relation(fields: [leadId], references: [id], name: "ProjectLead")
  issues      Issue[]

  @@index([workspaceId])
  @@index([teamId])
  @@index([leadId])
  @@map("project")
}

model Cycle {
  id          String      @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      CycleStatus @default(UPCOMING)
  createdAt   DateTime    @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  issues      Issue[]

  @@index([workspaceId])
  @@index([teamId])
  @@map("cycle")
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String // e.g., "#4EC9B0"
  createdAt DateTime @default(now())

  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  issueLabels IssueLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([teamId])
  @@map("label")
}

model Issue {
  id            String      @id @default(cuid())
  identifier    String // e.g., "ENG-123"
  number        Int // Auto-increment per team
  title         String
  description   String? // JSON string for TipTap content
  status        IssueStatus @default(BACKLOG)
  priority      Priority    @default(NO_PRIORITY)
  dueDate       DateTime?
  estimatedTime Float? // Estimated time in hours
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  cycleId     String?
  cycle       Cycle?    @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id], name: "AssignedIssues")
  creatorId   String
  creator     User      @relation(fields: [creatorId], references: [id], name: "CreatedIssues")

  labels        IssueLabel[]
  comments      Comment[]
  history       IssueHistory[]
  notifications Notification[]
  pullRequests  GitHubPullRequest[]
  timeEntries   TimeEntry[]

  @@unique([teamId, number])
  @@index([workspaceId])
  @@index([teamId])
  @@index([projectId])
  @@index([cycleId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([status])
  @@index([priority])
  @@map("issue")
}

model IssueLabel {
  id      String @id @default(cuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  labelId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([issueId, labelId])
  @@index([labelId])
  @@map("issue_label")
}

model TimeEntry {
  id          String    @id @default(cuid())
  duration    Float // Duration in hours (can be fractional like 0.5 for 30 minutes)
  description String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  isRunning   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  issueId     String
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([userId])
  @@index([workspaceId])
  @@index([startedAt])
  @@index([isRunning])
  @@map("time_entry")
}

model Comment {
  id        String   @id @default(cuid())
  content   String // JSON string for TipTap content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issueId  String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([issueId])
  @@index([authorId])
  @@map("comment")
}

model IssueHistory {
  id        String   @id @default(cuid())
  field     String // e.g., "status", "assignee", "priority"
  oldValue  String? // JSON string
  newValue  String // JSON string
  createdAt DateTime @default(now())

  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  @@index([issueId])
  @@index([actorId])
  @@map("issue_history")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  content   String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Related entities
  userId      String
  user        User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issueId     String?
  issue       Issue?    @relation(fields: [issueId], references: [id], onDelete: SetNull)
  actorId     String? // User who triggered the notification
  actor       User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  // For mention notifications
  mentionedInComment Boolean @default(false)

  @@index([userId])
  @@index([workspaceId])
  @@index([issueId])
  @@index([read, createdAt])
  @@map("notification")
}

model NotificationPreferences {
  id                   String   @id @default(cuid())
  notifyOnAssign       Boolean  @default(true)
  notifyOnMention      Boolean  @default(true)
  notifyOnStatusChange Boolean  @default(true)
  notifyOnComment      Boolean  @default(true)
  notifyOnIssueCreated Boolean  @default(false)
  notifyOnCycleStart   Boolean  @default(true)
  notifyOnCycleEnd     Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@map("notification_preferences")
}

model Template {
  id          String      @id @default(cuid())
  name        String
  description String?
  title       String // Default title for issues created from this template
  content     String? // Default description/content (JSON for TipTap)
  priority    Priority    @default(NO_PRIORITY)
  status      IssueStatus @default(BACKLOG)
  isDefault   Boolean     @default(false) // System default templates
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  labelIds    String // JSON array of label IDs to apply

  @@index([workspaceId])
  @@index([teamId])
  @@index([isDefault])
  @@map("template")
}

model AutomationRule {
  id          String            @id @default(cuid())
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  String // JSON array of conditions
  actions     String // JSON array of actions
  enabled     Boolean           @default(true)
  isTemplate  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  logs        AutomationLog[]

  @@index([workspaceId])
  @@index([teamId])
  @@index([enabled])
  @@index([isTemplate])
  @@map("automation_rule")
}

model AutomationLog {
  id         String              @id @default(cuid())
  status     AutomationLogStatus @default(SUCCESS)
  error      String? // Error message if failed
  inputData  String // JSON of the trigger event data
  outputData String? // JSON of actions taken
  executedAt DateTime            @default(now())

  ruleId      String
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issueId     String?

  @@index([ruleId])
  @@index([workspaceId])
  @@index([executedAt])
  @@index([status])
  @@map("automation_log")
}

// Enums

enum AutomationTrigger {
  ISSUE_CREATED
  ISSUE_UPDATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  PRIORITY_CHANGED
}

enum AutomationLogStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CycleStatus {
  UPCOMING
  CURRENT
  COMPLETED
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  NO_PRIORITY
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  ASSIGNED
  MENTIONED
  STATUS_CHANGED
  COMMENTED
  ISSUE_CREATED
  CYCLE_STARTED
  CYCLE_ENDED
}

// API Keys & Webhooks

enum ApiKeyScope {
  READ
  WRITE
  ADMIN
}

model ApiKey {
  id          String      @id @default(cuid())
  name        String
  keyHash     String      @unique // Hashed key for storage
  keyPrefix   String // First 8 chars of key for display
  scope       ApiKeyScope @default(READ)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isRevoked   Boolean     @default(false)
  revokedAt   DateTime?
  revokedById String?
  createdAt   DateTime    @default(now())

  // Rate limiting
  rateLimitRequests Int @default(1000) // Requests per hour

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String

  @@index([workspaceId])
  @@index([keyHash])
  @@index([isRevoked])
  @@index([createdAt])
  @@map("api_key")
}

enum WebhookEvent {
  ISSUE_CREATED
  ISSUE_UPDATED
  ISSUE_DELETED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  FAILED
}

model Webhook {
  id        String        @id @default(cuid())
  name      String
  url       String
  events    String // JSON array of WebhookEvent
  secret    String // For HMAC signature
  status    WebhookStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String
  deliveries  WebhookDelivery[]

  @@index([workspaceId])
  @@index([status])
  @@map("webhook")
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

model WebhookDelivery {
  id           String         @id @default(cuid())
  eventType    WebhookEvent
  payload      String // JSON payload
  status       DeliveryStatus @default(PENDING)
  responseCode Int?
  responseBody String?
  errorMessage String?
  attemptCount Int            @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_delivery")
}

// GitHub Integration Models

enum PullRequestStatus {
  OPEN
  MERGED
  CLOSED
  DRAFT
}

model GitHubPullRequest {
  id         String            @id @default(cuid())
  githubId   String // GitHub PR ID
  number     Int // PR number in the repo
  title      String
  url        String // GitHub PR URL
  status     PullRequestStatus @default(OPEN)
  branch     String // Source branch name
  baseBranch String // Target branch name
  author     String // GitHub username
  repository String // Full repo name (owner/repo)
  mergedAt   DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  issueId     String
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([issueId, githubId])
  @@index([workspaceId])
  @@index([issueId])
  @@index([status])
  @@index([repository])
  @@map("github_pull_request")
}
